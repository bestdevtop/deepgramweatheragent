APP_NAME=Weather Voice Agent API (Deepgram)
CORS_ORIGINS=["http://localhost:3000"]

# Required — Deepgram Voice Agent (STT + LLM + TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Voice agent model settings
VOICE_MODEL=aura-2-thalia-en
LLM_MODEL=gpt-4o-mini

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# Public URL where Twilio can reach this server (e.g. https://xxxx.ngrok.io)
SERVER_EXTERNAL_URL=

# Optional webhook path token (return 404 when mismatch)
WEBHOOK_SECRET=

OPENWEATHER_API_KEY=your_openweather_api_key
COLD_THRESHOLD_F=50

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567

# Email fallback when SMS fails (Gmail SMTP — use a Google App Password, not your login password)
FROM_EMAIL=yourname@gmail.com
TO_EMAIL=yourname@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
